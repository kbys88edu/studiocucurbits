---
import BaseLayout from '../layouts/BaseLayout.astro';

const { locale = 'en' } = Astro.props;
---

<BaseLayout
  title="About | Studio Cucurbits."
  description="The people and approach behind Studio Cucurbits."
  canonicalPath={locale === 'ja' ? '/ja/about/' : '/about/'}
  locale={locale}
>
  <section class="page-intro" aria-labelledby="about-title">
    <p class="eyebrow">About</p>
    <h1 id="about-title">Studio Cucurbits.</h1>
    <p class="lead">A music and creative-technology studio working across composition, sound design, AI audio, spatial sound, and performance.</p>
  </section>

  <section class="section copy-block" aria-labelledby="biography-title">
    <h2 id="biography-title">Studio</h2>
    <p>Studio Cucurbits. builds on the ongoing collaboration between composer and creative technologist Sachie Kobayashi and voice AI researcher Frederik Bous.</p>
    <p>The studio brings artistic expression and research and development into one making process, treating voice, timbre, bodies, instruments, and space as materials for each project.</p>
  </section>

  <section class="section" aria-labelledby="people-title">
    <p class="eyebrow">People</p>
    <h2 id="people-title">People</h2>
    <div class="people-grid">
      <article class="person-card">
        <img src="/images/studio/bw_sachie_cucurbits.png" alt="Sachie Kobayashi" width="1254" height="1254" loading="lazy" decoding="async" />
        <p>Founder / Composer / Creative Technologist</p>
        <h3>Sachie Kobayashi</h3>
        <a class="text-link" href="https://www.sachiekobayashi.com/" rel="noreferrer">Website</a>
      </article>
      <article class="person-card">
        <img src="/images/studio/bw_fred_cucurbits.png" alt="Frederik Bous" width="1254" height="1254" loading="lazy" decoding="async" />
        <p>Research Scientist / Voice AI</p>
        <h3>Frederik Bous</h3>
        <a class="text-link" href="https://frederik.bous.cc/" rel="noreferrer">Website</a>
      </article>
    </div>
  </section>

  <section class="section copy-block" aria-labelledby="approach-title">
    <p class="eyebrow">Approach</p>
    <h2 id="approach-title">AI can expand sound. Human listening decides meaning.</h2>
    <p>Studio Cucurbits. approaches sound through context, listening, performance, and responsibility.</p>
  </section>
</BaseLayout>

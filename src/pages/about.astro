---
import BaseLayout from '../layouts/BaseLayout.astro';

const { locale = 'en' } = Astro.props;
const copy = locale === 'ja'
  ? { title: 'Studio Cucurbits.について | Studio Cucurbits.', description: 'Studio Cucurbits.の人々とアプローチ。', eyebrow: 'Studio Cucurbits.について', lead: '作曲、サウンドデザイン、AIオーディオ、空間音響、パフォーマンスを横断する、音楽とクリエイティブテクノロジーのスタジオ。', studio: 'スタジオ', studioOne: 'Studio Cucurbits.は、作曲家・クリエイティブテクノロジストの小林幸枝と、音声AI研究者のFrederik Bousによる継続的な協働を基盤としています。', studioTwo: '声、音色、身体、楽器、空間を各プロジェクトの素材として捉え、芸術表現と研究開発をひとつの制作プロセスに結びます。', people: '人々', sachie: '創設者 / 作曲家 / クリエイティブテクノロジスト', frederik: 'リサーチサイエンティスト / 音声AI', website: 'ウェブサイト', approach: 'アプローチ', approachTitle: 'AIは音を広げられる。意味を決めるのは、人の聴くこと。', approachText: 'Studio Cucurbits.は、文脈、聴くこと、パフォーマンス、責任を通して音に向き合います。' }
  : { title: 'About | Studio Cucurbits.', description: 'The people and approach behind Studio Cucurbits.', eyebrow: 'About', lead: 'A music and creative-technology studio working across composition, sound design, AI audio, spatial sound, and performance.', studio: 'Studio', studioOne: 'Studio Cucurbits. builds on the ongoing collaboration between composer and creative technologist Sachie Kobayashi and voice AI researcher Frederik Bous.', studioTwo: 'The studio brings artistic expression and research and development into one making process, treating voice, timbre, bodies, instruments, and space as materials for each project.', people: 'People', sachie: 'Founder / Composer / Creative Technologist', frederik: 'Research Scientist / Voice AI', website: 'Website', approach: 'Approach', approachTitle: 'AI can expand sound. Human listening decides meaning.', approachText: 'Studio Cucurbits. approaches sound through context, listening, performance, and responsibility.' };
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={locale === 'ja' ? '/ja/about/' : '/about/'}
  locale={locale}
>
  <section class="page-intro" aria-labelledby="about-title">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="about-title">Studio Cucurbits.</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="section copy-block" aria-labelledby="biography-title">
    <h2 id="biography-title">{copy.studio}</h2>
    <p>{copy.studioOne}</p>
    <p>{copy.studioTwo}</p>
  </section>

  <section class="section" aria-labelledby="people-title">
    <p class="eyebrow">{copy.people}</p>
    <h2 id="people-title">{copy.people}</h2>
    <div class="people-grid">
      <article class="person-card">
        <img src="/images/studio/bw_sachie_cucurbits.png" alt="Sachie Kobayashi" width="1254" height="1254" loading="lazy" decoding="async" />
        <p>{copy.sachie}</p>
        <h3>Sachie Kobayashi</h3>
        <a class="text-link" href="https://www.sachiekobayashi.com/" rel="noreferrer">{copy.website}</a>
      </article>
      <article class="person-card">
        <img src="/images/studio/bw_fred_cucurbits.png" alt="Frederik Bous" width="1254" height="1254" loading="lazy" decoding="async" />
        <p>{copy.frederik}</p>
        <h3>Frederik Bous</h3>
        <a class="text-link" href="https://frederik.bous.cc/" rel="noreferrer">{copy.website}</a>
      </article>
    </div>
  </section>

  <section class="section copy-block" aria-labelledby="approach-title">
    <p class="eyebrow">{copy.approach}</p>
    <h2 id="approach-title">{copy.approachTitle}</h2>
    <p>{copy.approachText}</p>
  </section>
</BaseLayout>

---
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getLocale } from '../../lib/locale';
import BaseLayout from '../../layouts/BaseLayout.astro';

const locale = getLocale(new URL(Astro.request.url));
const canonicalPath = locale === 'ja' ? '/ja/products/' : '/products/';
const copy = locale === 'ja'
  ? { title: 'オーディオ・インストゥルメンツ | Studio Cucurbits.', description: 'Studio CucurbitsのAudio Instrumentsは開発中です。', eyebrow: 'Studio Cucurbits / Audio Instruments', heading: 'オーディオ・インストゥルメンツ', lead: 'Studio Cucurbitsは、音のための新しいインストゥルメンツを準備しています。', development: '開発中', details: '個別製品、デモ、ベータ版は準備が整い次第お知らせします。', mailing: '今後のお知らせを受け取る' }
  : { title: 'Audio Instruments | Studio Cucurbits.', description: 'Audio Instruments from Studio Cucurbits are in development.', eyebrow: 'Studio Cucurbits / Audio Instruments', heading: 'Audio Instruments', lead: 'Studio Cucurbits is preparing a new area for sound.', development: 'In development', details: 'Individual instruments, demonstrations, and beta access will be announced when they are ready.', mailing: 'Receive future announcements' };
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
>
  <section class="page-intro" aria-labelledby="products-title">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="products-title">{copy.heading}</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="section" aria-labelledby="development-title">
    <figure class="product-overview-hero">
      <img src="/images/products/SC_Hero_2560x1440.png" width="2560" height="1440" alt="" loading="eager" decoding="async" />
    </figure>
    <p class="eyebrow">{copy.development}</p>
    <h2 id="development-title">{copy.development}</h2>
    <p class="lead">{copy.details}</p>
    <div class="product-overview-newsletter">
      <p class="eyebrow">{copy.mailing}</p>
      <NewsletterForm locale={locale} />
    </div>
  </section>
</BaseLayout>

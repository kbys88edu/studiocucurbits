---
import NewsletterForm from '../../components/NewsletterForm.astro';
import ProductCard from '../../components/ProductCard.astro';
import { isVisibleProduct, products } from '../../data/products';
import { getLocale, localizedPath } from '../../lib/locale';
import BaseLayout from '../../layouts/BaseLayout.astro';

const locale = getLocale(new URL(Astro.request.url));
const visibleProducts = products.filter(isVisibleProduct);
const canonicalPath = locale === 'ja' ? '/ja/products/' : '/products/';
const copy = locale === 'ja'
  ? { title: 'PRODUCTS | Studio Cucurbits.', description: 'Studio CucurbitsのProductsは、不安定な音のために作曲家が設計したオーディオ楽器です。', eyebrow: 'Studio Cucurbits / Products', heading: 'PRODUCTS', lead: '不安定な音のために、作曲家が設計したオーディオ楽器。', development: '公開状況', details: '製品、デモ、ベータ版は準備が整い次第お知らせします。', mailing: '今後のお知らせを受け取る' }
  : { title: 'PRODUCTS | Studio Cucurbits.', description: 'Artist-designed instruments for unstable sound from Studio Cucurbits.', eyebrow: 'Studio Cucurbits / Products', heading: 'PRODUCTS', lead: 'Artist-designed instruments for unstable sound.', development: 'Release status', details: 'Products, demonstrations, and beta access will be announced when they are ready.', mailing: 'Receive future announcements' };
const statusRows = locale === 'ja'
  ? [
      { name: 'SC Suspended', status: 'Coming Soon / Windows Beta', href: localizedPath('/products/suspended/', locale) },
      { name: 'Traces', status: 'Collection in development', href: null },
      { name: 'Tendril', status: 'Physical modelling collection in development', href: null },
      { name: 'SC Vitreous', status: 'Standalone material processor / Coming later', href: null },
    ]
  : [
      { name: 'SC Suspended', status: 'Coming Soon / Windows Beta', href: localizedPath('/products/suspended/', locale) },
      { name: 'Traces', status: 'Collection in development', href: null },
      { name: 'Tendril', status: 'Physical modelling collection in development', href: null },
      { name: 'SC Vitreous', status: 'Standalone material processor / Coming later', href: null },
    ];
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
>
  <section class="page-intro" aria-labelledby="products-title">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="products-title">{copy.heading}</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="section" aria-labelledby="development-title">
    <figure class="product-overview-hero">
      <img src="/images/products/contrast_SC_Hero_2560x1440.png" width="2560" height="1440" alt="" loading="eager" decoding="async" />
    </figure>
    <p class="eyebrow">{copy.development}</p>
    <h2 id="development-title">{copy.development}</h2>
    <p class="lead">{copy.details}</p>
    <div class="catalogue-status" aria-label={copy.development}>
      {statusRows.map((row) => <div class="catalogue-status-row"><h3>{row.href ? <a href={row.href}>{row.name}</a> : row.name}</h3><p>{row.status}</p></div>)}
    </div>
    <div class="product-overview-newsletter">
      <p class="eyebrow">{copy.mailing}</p>
      <NewsletterForm locale={locale} />
    </div>
  </section>

  <section class="section" aria-labelledby="catalogue-title">
    <p class="eyebrow">Products</p>
    <h2 id="catalogue-title">{locale === 'ja' ? '公開中の製品' : 'Current instrument'}</h2>
    <div class="catalogue-list">
      {visibleProducts.map((product) => <ProductCard product={product} locale={locale} />)}
    </div>
  </section>
</BaseLayout>

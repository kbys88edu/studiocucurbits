---
import ProductDetails from '../../components/ProductDetails.astro';
import ProductHero from '../../components/ProductHero.astro';
import ProductLaunch from '../../components/ProductLaunch.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import { getProductBySlug, isVisibleProduct, products } from '../../data/products';
import { getLocale } from '../../lib/locale';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return products
    .filter(isVisibleProduct)
    .map((product) => ({ params: { slug: product.slug } }));
}

const product = getProductBySlug(Astro.params.slug ?? '');
if (!product || product.status === 'hidden') return Astro.redirect('/products/');

const locale = getLocale(new URL(Astro.request.url));
const relatedProducts = product.relatedProductSlugs
  .map(getProductBySlug)
  .filter((related): related is NonNullable<typeof related> => Boolean(related && isVisibleProduct(related)))
  .slice(0, 3);
const editorial = product.editorial[locale].shortDescription ? product.editorial[locale] : product.editorial.en;
---

<BaseLayout
  title={product.seo.title ?? `${product.name} | Audio Instruments | Studio Cucurbits.`}
  description={product.seo.description ?? editorial.shortDescription ?? 'Audio Instrument from Studio Cucurbits.'}
  canonicalPath={`/products/${product.slug}/`}
  locale={locale}
  product={product}
  breadcrumbLabel={product.name}
>
  {product.launch ? <ProductLaunch product={product} locale={locale} /> : <>
    <ProductHero product={product} locale={locale} />
    <ProductDetails product={product} locale={locale} />
  </>}
  <RelatedProducts products={relatedProducts} locale={locale} />
</BaseLayout>

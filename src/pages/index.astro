---
import BaseLayout from '../layouts/BaseLayout.astro';
import LatestItem from '../components/LatestItem.astro';
import { latestItem, site } from '../data/site';
import { getLocale, localizedPath } from '../lib/locale';

const locale = getLocale(new URL(Astro.request.url));
---

<BaseLayout
  title="Studio Cucurbits. | Music and Creative Technology"
  description="Studio Cucurbits. is a music and creative technology studio."
  canonicalPath="/"
  locale={locale}
>
  <section class="hero" aria-labelledby="hero-title">
    <p class="eyebrow">Music / Sound / AI / Creative Technology</p>
    <h1 id="hero-title">Studio<br />Cucurbits.</h1>
    <p class="lead">A studio for composition, sound design, creative technology, and audio instruments.</p>
  </section>

  <section class="section latest" aria-labelledby="latest-title">
    <p class="eyebrow">Latest</p>
    <h2 id="latest-title">Current studio updates</h2>
    <LatestItem item={latestItem} locale={locale} />
  </section>

  <section class="section" aria-labelledby="areas-title">
    <p class="eyebrow">Studio areas</p>
    <h2 id="areas-title">Three ways of working with sound.</h2>
    <div class="area-grid">
      {site.businessAreas.map((area) => (
        <article class="area-card">
          <h3><a href={localizedPath(area.href, locale)}>{area.title}</a></h3>
          {area.description && <p>{area.description}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section statement" aria-labelledby="statement-title">
    <p class="eyebrow">Studio statement</p>
    <h2 id="statement-title">Sound comes first.</h2>
    <p class="lead">AI can expand sound. Human listening decides meaning.</p>
  </section>

  <section class="section notification" aria-labelledby="notification-title">
    <p class="eyebrow">Stay in touch</p>
    <h2 id="notification-title">Receive studio updates.</h2>
    <a class="button" href={localizedPath('/newsletter/', locale)}>Notify me</a>
  </section>
</BaseLayout>

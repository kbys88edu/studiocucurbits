---
import BaseLayout from '../layouts/BaseLayout.astro';
import LatestItem from '../components/LatestItem.astro';
import { latestItem, site } from '../data/site';
import { getLocale, localizedPath } from '../lib/locale';

const locale = getLocale(new URL(Astro.request.url));
const canonicalPath = locale === 'ja' ? '/ja/' : '/';
const copy = locale === 'ja'
  ? {
    title: 'Studio Cucurbits. | 音楽とクリエイティブテクノロジー', description: 'Studio Cucurbits.は、音楽とクリエイティブテクノロジーに取り組むスタジオです。',
    eyebrow: '音楽 / サウンド / AI / クリエイティブテクノロジー', lead: '作曲、サウンドデザイン、クリエイティブテクノロジー、オーディオ・インストゥルメンツを横断するスタジオ。',
    latest: '最新情報', latestTitle: 'スタジオからの最新情報', areas: 'スタジオの活動領域', areasTitle: '音と向き合う、三つの領域。',
    statement: 'スタジオ・ステートメント', statementTitle: '音を、はじめに。', statementLead: 'AIは音を広げられる。意味を決めるのは、人の聴くこと。',
    contact: '最新情報を受け取る', contactTitle: 'スタジオからのお知らせを受け取る。', notify: 'お知らせを受け取る',
  }
  : {
    title: 'Studio Cucurbits. | Music and Creative Technology', description: 'Studio Cucurbits. is a music and creative technology studio.',
    eyebrow: 'Music / Sound / AI / Creative Technology', lead: 'A studio for composition, sound design, creative technology, and audio instruments.',
    latest: 'Latest', latestTitle: 'Current studio updates', areas: 'Studio areas', areasTitle: 'Three ways of working with sound.',
    statement: 'Studio statement', statementTitle: 'Sound comes first.', statementLead: 'AI can expand sound. Human listening decides meaning.',
    contact: 'Stay in touch', contactTitle: 'Receive studio updates.', notify: 'Notify me',
  };
const areaTitles = locale === 'ja'
  ? { 'composition-sound-design': '作曲 / サウンドデザイン', 'creative-technology-ai-audio': 'クリエイティブテクノロジー / AIオーディオ', 'audio-instruments': 'オーディオ・インストゥルメンツ' }
  : null;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
>
  <section class="hero" aria-labelledby="hero-title">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="hero-title">Studio<br />Cucurbits.</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="section latest" aria-labelledby="latest-title">
    <p class="eyebrow">{copy.latest}</p>
    <h2 id="latest-title">{copy.latestTitle}</h2>
    <LatestItem item={latestItem} locale={locale} />
  </section>

  <section class="section" aria-labelledby="areas-title">
    <p class="eyebrow">{copy.areas}</p>
    <h2 id="areas-title">{copy.areasTitle}</h2>
    <div class="area-grid">
      {site.businessAreas.map((area) => (
        <article class="area-card">
          <h3><a href={localizedPath(area.href, locale)}>{areaTitles?.[area.slug as keyof typeof areaTitles] ?? area.title}</a></h3>
          {area.description && <p>{area.description}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section statement" aria-labelledby="statement-title">
    <p class="eyebrow">{copy.statement}</p>
    <h2 id="statement-title">{copy.statementTitle}</h2>
    <p class="lead">{copy.statementLead}</p>
  </section>

  <section class="section notification" aria-labelledby="notification-title">
    <p class="eyebrow">{copy.contact}</p>
    <h2 id="notification-title">{copy.contactTitle}</h2>
    <a class="button" href={localizedPath('/newsletter/', locale)}>{copy.notify}</a>
  </section>
</BaseLayout>

---
import AudioComparison from '../../components/AudioComparison.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import VideoSlot from '../../components/VideoSlot.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="ニュースレター | Studio Cucurbits." description="Studio Cucurbits.から最新情報を受け取るためのニュースレター。" canonicalPath="/ja/newsletter/" locale="ja">
  <section class="page-intro" aria-labelledby="newsletter-title">
    <p class="eyebrow">スタジオからのお知らせ</p>
    <h1 id="newsletter-title">ニュースレター</h1>
    <p class="lead">オーディオ・インストゥルメンツ、作品、パフォーマンスの最新情報を、ときどきお届けします。</p>
    <NewsletterForm locale="ja" />
  </section>
  <section class="section">
    <VideoSlot poster="/images/studio/projection-performance.jpg" />
    <AudioComparison />
  </section>
</BaseLayout>

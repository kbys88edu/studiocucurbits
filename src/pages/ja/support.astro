---
import Faq from '../../components/Faq.astro';
import SupportGuide from '../../components/SupportGuide.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const faq = [
  { question: 'プラグインが一覧に表示されない場合は？', answer: 'ホストアプリケーションを再起動し、プラグインのスキャンまたは再スキャンを実行してください。' },
  { question: '不具合の報告には何を含めればよいですか？', answer: '製品名とバージョン、ホストアプリケーション名とバージョン、OS、プラグイン形式、再現手順、エラーメッセージまたはスクリーンショットをお知らせください。' },
];
---

<BaseLayout title="サポート | Studio Cucurbits." description="インストールとトラブルシューティングの基本案内。" canonicalPath="/ja/support/" locale="ja">
  <section class="page-intro" aria-labelledby="support-title">
    <p class="eyebrow">オーディオ・インストゥルメンツ</p>
    <h1 id="support-title">サポート</h1>
    <p class="lead">インストールとトラブルシューティングの基本案内です。製品固有の互換性については、確認済みの情報だけを掲載します。</p>
  </section>
  <SupportGuide locale="ja" />
  <Faq items={faq} locale="ja" />
</BaseLayout>

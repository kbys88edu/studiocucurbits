---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Work | Studio Cucurbits."
  description="An editable index for Studio Cucurbits work."
  canonicalPath="/work/"
>
  <section class="page-intro" aria-labelledby="work-title">
    <p class="eyebrow">Work</p>
    <h1 id="work-title">Studio work</h1>
    <p class="lead">An editable space for studio work approved for publication.</p>
  </section>

  <section class="section work-boundary" aria-labelledby="work-boundary-title">
    <img src="/images/studio/theatre-control.jpg" alt="Theatre control and projection stage" width="2048" height="1536" loading="lazy" decoding="async" />
    <div>
      <h2 id="work-boundary-title">Selected work</h2>
      <p>New entries can be added here when their title, context, and publication approval are available.</p>
    </div>
  </section>
</BaseLayout>

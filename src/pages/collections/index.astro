---
import CollectionCard from '../../components/CollectionCard.astro';
import { collections, isVisibleCollection } from '../../data/products';
import { getLocale } from '../../lib/locale';
import BaseLayout from '../../layouts/BaseLayout.astro';

const visibleCollections = collections.filter(isVisibleCollection);
const locale = getLocale(new URL(Astro.request.url));
const canonicalPath = locale === 'ja' ? '/ja/collections/' : '/collections/';
const copy = locale === 'ja'
  ? { title: 'コレクション | オーディオ・インストゥルメンツ | Studio Cucurbits.', description: 'Studio CucurbitsのAudio Instrumentsコレクション。', eyebrow: 'Studio Cucurbits / オーディオ・インストゥルメンツ', heading: 'コレクション', lead: 'Studio Cucurbits Audio Instrumentsカタログのインストゥルメント・コレクション。', catalogue: 'カタログ', current: 'TracesとTendril' }
  : { title: 'Collections | Audio Instruments | Studio Cucurbits.', description: 'Audio Instruments collections from Studio Cucurbits.', eyebrow: 'Studio Cucurbits / Audio Instruments', heading: 'Collections', lead: 'Instrument collections from the Studio Cucurbits Audio Instruments catalogue.', catalogue: 'Catalogue', current: 'Traces and Tendril' };
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  locale={locale}
>
  <section class="page-intro" aria-labelledby="collections-title">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1 id="collections-title">{copy.heading}</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="section" aria-labelledby="collection-list-title">
    <p class="eyebrow">{copy.catalogue}</p>
    <h2 id="collection-list-title">{copy.current}</h2>
    <div class="catalogue-list">
      {visibleCollections.map((collection) => <CollectionCard collection={collection} locale={locale} />)}
    </div>
  </section>
</BaseLayout>

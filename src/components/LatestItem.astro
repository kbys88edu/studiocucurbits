---
import type { LatestItem as LatestItemModel } from '../data/site';
import { localizedPath, type Locale } from '../lib/locale';
import StatusLabel from './StatusLabel.astro';

interface Props {
  item: LatestItemModel;
  locale: Locale;
}

const { item, locale } = Astro.props;
const href = item.href.trim() ? localizedPath(item.href, locale) : '';
---

<article class="latest-item">
  {item.image ? <img src={item.image} alt="" loading="lazy" decoding="async" /> : <div class="media-placeholder" aria-hidden="true" />}
  <p class="eyebrow">{item.type === 'instrument' ? 'Audio Instruments' : item.type}</p>
  <StatusLabel status={item.status} locale={locale} />
  <h3>{href ? <a href={href}>{item.title}</a> : item.title}</h3>
  <p>{item.summary}</p>
</article>

---
import type { Product } from '../data/products';
import { getDictionary } from '../i18n';
import type { Locale } from '../lib/locale';
import { formatPrice, getDisplayPrice } from '../lib/product';

interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const currency = locale === 'ja' ? 'JPY' : 'USD';
const price = getDisplayPrice(product, new Date(), currency);
const copy = getDictionary(locale).pricing;
---

{price && (
  <dl class="price">
    <dt>{price.kind === 'intro' ? copy.introPrice : copy.price}</dt>
    <dd>{formatPrice(price.amount, currency, locale)}</dd>
  </dl>
)}

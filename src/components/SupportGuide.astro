---
import type { Locale } from '../lib/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = locale === 'ja'
  ? {
      eyebrow: '基本ガイド',
      title: '\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3068\u30d7\u30e9\u30b0\u30a4\u30f3\u306e\u30b9\u30ad\u30e3\u30f3',
      steps: [
        'プラグインをインストールまたは更新する前に、DAWなどのホストアプリケーションを終了してください。',
        '製品と一緒に案内された配布元からのみインストールしてください。',
        'ホストを再起動し、プラグインのスキャンまたは再スキャンを実行してください。',
        'Appleシリコンでは、対応している場合はホストのネイティブ版を使用してから、再スキャンしてください。',
      ],
    }
  : {
      eyebrow: 'Editable guidance',
      title: 'Installation and plugin scanning',
      steps: [
        'Quit your host application before installing or updating a plug-in.',
        'Install only from the delivery location supplied with your product.',
        'Restart the host and run its plug-in scan or rescan command.',
        'On Apple silicon, use the native version of your host where available, then rescan.',
      ],
    };
---

<section class="section" aria-labelledby="support-guide-title">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h2 id="support-guide-title">{copy.title}</h2>
  <ol>{copy.steps.map((step) => <li>{step}</li>)}</ol>
  {locale === 'ja' ? (
    <p>VST3の保存場所は、Windowsでは <code>C:\Program Files\Common Files\VST3</code>、macOSでは <code>/Library/Audio/Plug-Ins/VST3</code> または <code>~/Library/Audio/Plug-Ins/VST3</code> です。AUの保存場所は <code>/Library/Audio/Plug-Ins/Components</code> と <code>~/Library/Audio/Plug-Ins/Components</code> です。</p>
  ) : (
    <p>Common VST3 locations include <code>C:\Program Files\Common Files\VST3</code> on Windows and <code>/Library/Audio/Plug-Ins/VST3</code> or <code>~/Library/Audio/Plug-Ins/VST3</code> on macOS. Common AU locations include <code>/Library/Audio/Plug-Ins/Components</code> and <code>~/Library/Audio/Plug-Ins/Components</code>.</p>
  )}
</section>

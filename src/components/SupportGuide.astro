---
import type { Locale } from '../lib/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = locale === 'ja'
  ? {
      eyebrow: '\u7de8\u96c6\u53ef\u80fd\u306a\u30ac\u30a4\u30c9',
      title: '\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3068\u30d7\u30e9\u30b0\u30a4\u30f3\u306e\u30b9\u30ad\u30e3\u30f3',
      steps: [
        '\u30d7\u30e9\u30b0\u30a4\u30f3\u306e\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u307e\u305f\u306f\u66f4\u65b0\u306e\u524d\u306b\u3001\u30db\u30b9\u30c8\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3092\u7d42\u4e86\u3057\u307e\u3059\u3002',
        '\u88fd\u54c1\u3068\u5171\u306b\u63d0\u4f9b\u3055\u308c\u305f\u914d\u5e03\u5143\u304b\u3089\u306e\u307f\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3057\u3066\u304f\u3060\u3055\u3044\u3002',
        '\u30db\u30b9\u30c8\u3092\u518d\u8d77\u52d5\u3057\u3001\u30d7\u30e9\u30b0\u30a4\u30f3\u306e\u30b9\u30ad\u30e3\u30f3\u307e\u305f\u306f\u518d\u30b9\u30ad\u30e3\u30f3\u3092\u5b9f\u884c\u3057\u307e\u3059\u3002',
        'Apple silicon\u3067\u306f\u3001\u5229\u7528\u3067\u304d\u308b\u5834\u5408\u306f\u30db\u30b9\u30c8\u306e\u30cd\u30a4\u30c6\u30a3\u30d6\u7248\u3092\u4f7f\u7528\u3057\u3066\u304b\u3089\u518d\u30b9\u30ad\u30e3\u30f3\u3057\u3066\u304f\u3060\u3055\u3044\u3002',
      ],
    }
  : {
      eyebrow: 'Editable guidance',
      title: 'Installation and plugin scanning',
      steps: [
        'Quit your host application before installing or updating a plug-in.',
        'Install only from the delivery location supplied with your product.',
        'Restart the host and run its plug-in scan or rescan command.',
        'On Apple silicon, use the native version of your host where available, then rescan.',
      ],
    };
---

<section class="section" aria-labelledby="support-guide-title">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h2 id="support-guide-title">{copy.title}</h2>
  <ol>{copy.steps.map((step) => <li>{step}</li>)}</ol>
  {locale === 'ja' ? (
    <p>一般的なVST3の場所は、Windowsでは <code>C:\Program Files\Common Files\VST3</code>、macOSでは <code>/Library/Audio/Plug-Ins/VST3</code> または <code>~/Library/Audio/Plug-Ins/VST3</code> です。一般的なAUの場所は <code>/Library/Audio/Plug-Ins/Components</code> と <code>~/Library/Audio/Plug-Ins/Components</code> です。</p>
  ) : (
    <p>Common VST3 locations include <code>C:\Program Files\Common Files\VST3</code> on Windows and <code>/Library/Audio/Plug-Ins/VST3</code> or <code>~/Library/Audio/Plug-Ins/VST3</code> on macOS. Common AU locations include <code>/Library/Audio/Plug-Ins/Components</code> and <code>~/Library/Audio/Plug-Ins/Components</code>.</p>
  )}
</section>

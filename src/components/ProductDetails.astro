---
import type { Product } from '../data/products';
import type { Locale } from '../lib/locale';

interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const editorial = product.editorial[locale].description ? product.editorial[locale] : product.editorial.en;
const hasCompatibility = product.supportedFormats.length > 0 || product.supportedPlatforms.length > 0 || product.compatibilityNotes;
---

{editorial.description && (
  <section class="section copy-block" aria-labelledby="details-title">
    <p class="eyebrow">Instrument</p>
    <h2 id="details-title">Details</h2>
    <p class="lead">{editorial.description}</p>
    {editorial.features.length > 0 && <ul>{editorial.features.map((feature) => <li>{feature}</li>)}</ul>}
  </section>
)}

{hasCompatibility && (
  <section class="section copy-block" aria-labelledby="compatibility">
    <p class="eyebrow">Technical</p>
    <h2 id="compatibility">Compatibility</h2>
    {product.supportedFormats.length > 0 && <p>Formats: {product.supportedFormats.join(', ')}</p>}
    {product.supportedPlatforms.length > 0 && <p>Platforms: {product.supportedPlatforms.join(', ')}</p>}
    {product.compatibilityNotes && <p>{product.compatibilityNotes}</p>}
  </section>
)}

---
interface Props {
  drySrc?: string;
  wetSrc?: string;
}

const { drySrc, wetSrc } = Astro.props;
const samples = [
  { id: 'dry', label: 'dry', src: drySrc },
  { id: 'wet', label: 'wet', src: wetSrc },
].filter((sample): sample is { id: string; label: string; src: string } => Boolean(sample.src));
---

{samples.length ? (
  <section class="audio-comparison" data-audio-comparison-root aria-label="Audio comparison">
    <p data-audio-loading aria-live="polite">Loading audio…</p>
    {samples.map(({ id, label, src }) => (
      <div data-audio-control>
        <audio data-audio-comparison preload="metadata"><source src={src} /></audio>
        <button type="button" data-audio-toggle data-audio-variant={id}>Play {label}</button>
        <button type="button" data-audio-stop>Stop {label}</button>
      </div>
    ))}
  </section>
) : <p class="media-placeholder">Audio comparison in production</p>}

<script>
  import { initAudioComparisons } from '../scripts/audio-comparison';

  initAudioComparisons();
</script>
